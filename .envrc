strict_env
direnv_version 2.37.1

watch_file pyproject.toml uv.lock .codex/config.toml src/cue-workbook/cue-workbook.py

has uv || {
  log_error "uv is required"
  return 1
}

export CUESTRAP_ROOT="$PWD"
export CUESTRAP_WORKBOOK="$PWD/src/cue-workbook/cue-workbook.py"
export UV_PROJECT_ENVIRONMENT="$PWD/.venv"
export VIRTUAL_ENV="$UV_PROJECT_ENVIRONMENT"
unset PYTHONHOME

if [[ ! -x "$VIRTUAL_ENV/bin/python" ]]; then
  log_error "missing locked environment; run: uv sync --locked --exact"
  return 1
fi

PATH_add "$VIRTUAL_ENV/bin"

uv lock --check --project "$PWD" >/dev/null || {
  log_error "uv.lock does not match pyproject.toml"
  return 1
}

uv sync --check --locked --exact --project "$PWD" >/dev/null || {
  log_error "the active uv environment is not exactly synchronized"
  return 1
}

[[ "$(command -v python)" == "$VIRTUAL_ENV/bin/python" ]] || {
  log_error "python does not resolve to the cuestrap uv environment"
  return 1
}
