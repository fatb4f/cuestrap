+		configBin = filepath.Join(filepath.Dir(bin), "python-config")
+	}
+	if includes, err := exec.Command(configBin, "--includes").Output(); err == nil {
+		if value := strings.TrimSpace(string(includes)); value != "" {
+			cfg.CFlags = value
+		}
+	}
+	if ldflags, err := exec.Command(configBin, "--embed", "--ldflags").Output(); err == nil {
+		if value := strings.TrimSpace(string(ldflags)); value != "" {
+			cfg.LdFlags = value
+		}
+	}
 	cfg.LdDynamicFlags = raw.ShFlags
 
 	return cfg, nil
